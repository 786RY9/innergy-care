# ─────────────────────────────────────────────────────────────────────────────
# TinaCMS — Required for the /admin panel and Tina Cloud content sync
#
# How to get these values:
#   1. Go to https://app.tina.io and create a free account
#   2. Create a new project and connect your GitHub repository
#   3. Find the values in your project's "Overview" and "Tokens" pages
#
# IMPORTANT: Copy this file to .env.local and fill in real values.
#            Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Your Tina Cloud project's Client ID
# Found at: https://app.tina.io → your project → Overview tab
TINA_CLIENT_ID=

# Your Tina Cloud Content API token (read-only token)
# Found at: https://app.tina.io → your project → Tokens tab → "Content token"
TINA_TOKEN=

# The git branch TinaCMS reads and writes content to (usually "main")
TINA_BRANCH=main
